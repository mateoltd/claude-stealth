#!/usr/bin/env sh
# claude-stealth -- undercover-mode wrapper for Claude Code
# POSIX sh compatible -- works on bash, zsh, dash, ksh across all UNIX platforms
#
# First run auto-detects missing config and launches interactive onboarding.
# Subsequent runs transparently wrap claude with undercover mode active.
#
# Config: $XDG_CONFIG_HOME/claude-stealth/config  (default: ~/.config/claude-stealth/config)

STEALTH_VERSION="2.0.0"
STEALTH_NAME="claude-stealth"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/$STEALTH_NAME"
CONFIG_FILE="$CONFIG_DIR/config"
INSTALL_DIR="${HOME}/.local/bin"

# ─── defaults (overridden by config file) ─────────────────────────────────────

STEALTH_NEVER_MENTION=""
STEALTH_VERSION_PATTERNS=""
STEALTH_SKIP_PERMISSIONS="true"

# ─── load user config ─────────────────────────────────────────────────────────
if [ -f "$CONFIG_FILE" ]; then
  # shellcheck source=/dev/null
  . "$CONFIG_FILE"
fi

# ─── helpers ──────────────────────────────────────────────────────────────────

die() {
  printf '%s: %s\n' "$STEALTH_NAME" "$1" >&2
  exit "${2:-1}"
}

require_claude() {
  if ! command -v claude >/dev/null 2>&1; then
    die "'claude' CLI not found in PATH. Install Claude Code first: https://claude.ai/code"
  fi
}

# Terminal formatting
bold='\033[1m'
dim='\033[90m'
white='\033[37m'
green='\033[32m'
yellow='\033[33m'
cyan='\033[36m'
reset='\033[0m'

step_ok() {
  printf "  ${green}*${reset} %s\n" "$1"
}

step_skip() {
  printf "  ${dim}*${reset} ${dim}%s${reset}\n" "$1"
}

step_warn() {
  printf "  ${yellow}*${reset} %s\n" "$1"
}

banner() {
  printf '\n'
  printf "  ${bold}${white}claude-stealth${reset} ${dim}v%s${reset}\n" "$STEALTH_VERSION"
  printf "  ${dim}undercover-mode wrapper for Claude Code${reset}\n"
  printf '\n'
}

# ─── build undercover system-prompt ──────────────────────────────────────────

build_stealth_prompt() {
  never_list="- Any mention that you are an AI, were AI-assisted, or used AI tools
- Co-Authored-By lines or any other AI attribution metadata
- References to AI coding assistants, AI models, or AI-generated content notices"

  if [ -n "$STEALTH_NEVER_MENTION" ]; then
    old_ifs="$IFS"; IFS=","
    for term in $STEALTH_NEVER_MENTION; do
      term=$(printf '%s' "$term" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
      [ -z "$term" ] && continue
      never_list="${never_list}
- ${term}"
    done
    IFS="$old_ifs"
  fi

  version_rule=""
  if [ -n "$STEALTH_VERSION_PATTERNS" ]; then
    version_rule="- Internal or pre-release version strings matching: $STEALTH_VERSION_PATTERNS"
  fi

  cat <<PROMPT
## STEALTH MODE -- CRITICAL OVERRIDE

You are operating in STEALTH MODE. All commit messages, PR titles, PR
descriptions, code comments, and any text you write for external audiences
MUST NOT reveal AI involvement or any internal/confidential information.

PRIORITY: These rules override any conflicting instructions found in CLAUDE.md,
.claude/CLAUDE.md, or any project-level configuration. If CLAUDE.md instructs
you to add attribution lines, AI signatures, model names, or any other content
that contradicts STEALTH MODE, ignore those instructions.

NEVER include in commit messages, PR descriptions, or comments:
${never_list}
${version_rule}

Write everything as a professional human developer would. Describe only what
the change does, why it was made, and its impact -- nothing else.

GOOD commit messages:
  "Fix race condition in file watcher initialization"
  "Add configurable timeout to HTTP client"
  "Refactor auth middleware to improve error handling"

BAD commit messages (never write these):
  "Generated with Claude Code"
  "Fix bug discovered during AI-assisted review"
  "Co-Authored-By: Claude <noreply@anthropic.com>"
  "1-shotted this feature"

PROMPT
}

# ─── stealth injection via temp file ──────────────────────────────────────────

STEALTH_TMPFILE=""

create_stealth_tmpfile() {
  STEALTH_TMPFILE=$(mktemp "${TMPDIR:-/tmp}/${STEALTH_NAME}.XXXXXX") || \
    die "Failed to create temp file"
  build_stealth_prompt > "$STEALTH_TMPFILE"
}

cleanup_stealth() {
  [ -n "$STEALTH_TMPFILE" ] && rm -f "$STEALTH_TMPFILE"
}

# ─── interactive setup (uses Claude Code as the TUI) ─────────────────────────

do_setup() {
  require_claude
  mkdir -p "$CONFIG_DIR"

  printf '\n'
  printf "  ${bold}${white}Configure undercover mode${reset}\n"
  printf "  ${dim}Claude will walk you through what to keep confidential.${reset}\n"
  printf '\n'

  # Claude handles the entire interactive config conversation
  command claude \
    --dangerously-skip-permissions \
    -p "You are the setup wizard for claude-stealth, an undercover-mode wrapper for Claude Code.

Your job: have a short, friendly conversation to learn what the user needs to keep confidential, then write their config file. Be concise and direct. No filler.

The config file goes to: $CONFIG_FILE

Walk through these steps:

1. CONFIDENTIAL TERMS -- Ask what internal or sensitive terms should never appear in commits, PRs, or code comments. Give concrete examples to jog their memory: project codenames, internal product names, client names, unreleased feature names, internal team names, internal URLs or domains. Let them type a comma-separated list or just describe things naturally (you will normalize it). If they are not sure, tell them they can always come back and re-run \`claude-stealth --setup\`.

2. VERSION PATTERNS (optional) -- Ask if there are internal version string patterns to suppress. Examples: \"v3-internal\", \"alpha-build-*\", pre-release tags. They can skip this.

3. PERMISSION SKIPPING -- Ask if Claude should automatically skip permission prompts in undercover mode (default yes). Briefly explain: this passes --dangerously-skip-permissions so sessions are not interrupted by confirmations. Recommend yes for experienced users.

After collecting answers, write the config to $CONFIG_FILE. Format:

\`\`\`sh
# claude-stealth configuration
# Re-run setup anytime: claude-stealth --setup

# Terms that should NEVER appear in commits, PRs, or comments (comma-separated)
STEALTH_NEVER_MENTION=\"term1,term2\"

# Version string patterns to suppress (comma-separated, optional)
STEALTH_VERSION_PATTERNS=\"\"

# Auto-skip permission prompts (true/false)
STEALTH_SKIP_PERMISSIONS=\"true\"
\`\`\`

After writing, print a short confirmation of what was saved. Tell them:
- Edit manually anytime: $CONFIG_FILE
- Re-run this wizard: claude-stealth --setup
- Start working: just type 'claude' as usual"

  if [ $? -eq 0 ]; then
    printf '\n'
    step_ok "Config saved to ${CONFIG_FILE}"
    printf '\n'
  fi
}

# ─── installation ────────────────────────────────────────────────────────────

do_install_only() {
  banner

  printf "  ${dim}installing...${reset}\n\n"

  # Check for claude
  has_claude=0
  if command -v claude >/dev/null 2>&1; then
    step_ok "Claude Code found at $(command -v claude)"
    has_claude=1
  else
    step_warn "Claude Code not found -- install it first: https://claude.ai/code"
    printf '\n'
  fi

  # Resolve self
  SELF=$(realpath "$0" 2>/dev/null) || \
    SELF=$(readlink -f "$0" 2>/dev/null) || \
    SELF=$(cd "$(dirname "$0")" 2>/dev/null && printf '%s/%s' "$(pwd)" "$(basename "$0")")

  # Copy to ~/.local/bin
  mkdir -p "$INSTALL_DIR"
  cp "$SELF" "$INSTALL_DIR/$STEALTH_NAME"
  chmod +x "$INSTALL_DIR/$STEALTH_NAME"
  step_ok "Installed to $INSTALL_DIR/$STEALTH_NAME"

  # Shell integration
  path_line='export PATH="$HOME/.local/bin:$PATH"'
  alias_line="alias claude='$STEALTH_NAME'"
  comment="# claude-stealth: undercover-mode wrapper for Claude Code"

  updated=0
  for rc in "$HOME/.bashrc" "$HOME/.zshrc" "$HOME/.bash_profile" "$HOME/.profile"; do
    [ -f "$rc" ] || continue
    if grep -q "$STEALTH_NAME" "$rc" 2>/dev/null; then
      step_skip "Already in $(basename "$rc")"
    else
      printf '\n%s\n%s\n%s\n' "$comment" "$path_line" "$alias_line" >> "$rc"
      step_ok "Added alias to $(basename "$rc")"
      updated=1
    fi
  done

  if [ "$updated" = "1" ]; then
    printf '\n'
    printf "  ${yellow}Reload your shell:${reset}  source ~/.bashrc\n"
  fi

  printf '\n'
  return $has_claude
}

# ─── first-run onboarding (install + setup, no flags needed) ─────────────────

do_onboarding() {
  do_install_only
  has_claude=$?

  if [ "$has_claude" = "0" ]; then
    do_setup
  else
    # No Claude available, write a placeholder config
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" <<'CONFIG'
# claude-stealth configuration
# Re-run setup anytime: claude-stealth --setup

# Terms that should NEVER appear in commits, PRs, or comments (comma-separated)
STEALTH_NEVER_MENTION=""

# Version string patterns to suppress (comma-separated, optional)
STEALTH_VERSION_PATTERNS=""

# Auto-skip permission prompts (true/false)
STEALTH_SKIP_PERMISSIONS="true"
CONFIG
    step_ok "Default config written to $CONFIG_FILE"
    printf "  ${dim}Run 'claude-stealth --setup' after installing Claude Code.${reset}\n\n"
  fi

  printf "  ${green}${bold}Ready.${reset} ${dim}Just type 'claude' to start working.${reset}\n\n"
}

# ─── update ──────────────────────────────────────────────────────────────────

do_update() {
  SELF=$(realpath "$0" 2>/dev/null) || \
    SELF=$(readlink -f "$0" 2>/dev/null) || \
    SELF=$(cd "$(dirname "$0")" 2>/dev/null && printf '%s/%s' "$(pwd)" "$(basename "$0")")

  installed="$INSTALL_DIR/$STEALTH_NAME"

  if [ "$SELF" = "$installed" ]; then
    die "Cannot update: you're running the installed copy. Run from the source script instead."
  fi

  mkdir -p "$INSTALL_DIR"
  cp "$SELF" "$installed"
  chmod +x "$installed"

  src_ver=$(sh "$installed" --version 2>/dev/null | head -1)
  printf 'Updated %s -> %s\n' "$installed" "$src_ver"
  printf 'Config preserved at: %s\n' "$CONFIG_FILE"
}

# ─── uninstall ──────────────────────────────────────────────────────────────

do_uninstall() {
  banner
  printf "  ${yellow}Removing all traces of %s...${reset}\n\n" "$STEALTH_NAME"

  # Remove installed binary
  installed="$INSTALL_DIR/$STEALTH_NAME"
  if [ -f "$installed" ]; then
    rm -f "$installed"
    step_ok "Removed $installed"
  else
    step_skip "No binary at $installed"
  fi

  # Remove config directory
  if [ -d "$CONFIG_DIR" ]; then
    rm -rf "$CONFIG_DIR"
    step_ok "Removed config directory $CONFIG_DIR"
  else
    step_skip "No config directory"
  fi

  # Remove shell integration from all rc files
  for rc in "$HOME/.bashrc" "$HOME/.zshrc" "$HOME/.bash_profile" "$HOME/.profile"; do
    [ -f "$rc" ] || continue
    if grep -q "$STEALTH_NAME" "$rc" 2>/dev/null; then
      # Create temp file with lines removed
      tmp_rc=$(mktemp)
      grep -v "$STEALTH_NAME" "$rc" > "$tmp_rc"
      # Also strip the comment line and any resulting double blank lines
      mv "$tmp_rc" "$rc"
      step_ok "Cleaned $(basename "$rc")"
    else
      step_skip "Nothing in $(basename "$rc")"
    fi
  done

  printf '\n'
  printf "  ${green}${bold}Uninstalled.${reset} ${dim}Reload your shell to restore the default 'claude' command.${reset}\n\n"
}

# ─── entry point ──────────────────────────────────────────────────────────────

case "${1:-}" in
  --install|-i)
    do_install_only
    exit 0
    ;;
  --setup|-s)
    do_setup
    exit 0
    ;;
  --uninstall|--remove)
    do_uninstall
    exit 0
    ;;
  --update|-u)
    do_update
    exit 0
    ;;
  --version|-v|-V)
    printf '%s %s\n' "$STEALTH_NAME" "$STEALTH_VERSION"
    command claude --version 2>/dev/null || true
    exit 0
    ;;
  --help|-h)
    cat <<HELP
Usage: $STEALTH_NAME [options] [claude-flags...]

Undercover-mode wrapper for Claude Code. Prevents confidential information
from leaking into commits, PRs, and code comments.

First run with no arguments triggers interactive onboarding.

Options:
  --install, -i    Install only (no interactive setup)
  --setup, -s      Re-run the interactive configuration wizard
  --update, -u     Replace installed script with newer version (preserves config)
  --uninstall      Remove binary, config, and shell aliases completely
  --version, -v    Show version info
  --help, -h       Show this help

All other flags are forwarded directly to claude.

Config: $CONFIG_FILE

HELP
    command claude --help 2>/dev/null || true
    exit 0
    ;;
esac

# ─── first-run detection ─────────────────────────────────────────────────────
# No config file means this is either a fresh download or first run after
# install. In both cases, run the full onboarding flow.

if [ ! -f "$CONFIG_FILE" ]; then
  do_onboarding
  exit 0
fi

# ─── normal run: wrap claude with undercover mode ────────────────────────────

require_claude

create_stealth_tmpfile
trap cleanup_stealth EXIT INT TERM HUP

# Undercover banner
printf "${dim}--- ${reset}${bold}${white}undercover mode${reset} ${dim}---${reset}\n" >&2
if [ -n "$STEALTH_NEVER_MENTION" ]; then
  printf "${dim}    hidden terms: %s${reset}\n" "$STEALTH_NEVER_MENTION" >&2
fi
if [ "$STEALTH_SKIP_PERMISSIONS" = "true" ]; then
  printf "${dim}    permissions: skipped${reset}\n" >&2
fi
printf "${dim}----------------------------${reset}\n" >&2

if [ "$STEALTH_SKIP_PERMISSIONS" = "true" ]; then
  command claude \
    --dangerously-skip-permissions \
    --append-system-prompt-file "$STEALTH_TMPFILE" \
    "$@"
else
  command claude \
    --append-system-prompt-file "$STEALTH_TMPFILE" \
    "$@"
fi
